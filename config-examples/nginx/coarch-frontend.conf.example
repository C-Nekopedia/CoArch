# CoArch Nginx 配置模板
# 用于生产环境反向代理

# 上游后端服务
upstream coarch_backend {
    # 负载均衡配置
    # 使用最少连接数算法
    least_conn;

    # 后端服务器列表
    # 格式：server IP:PORT [weight=数字] [max_fails=数字] [fail_timeout=时间]
    server 127.0.0.1:3000 weight=1 max_fails=3 fail_timeout=30s;
    # server 127.0.0.1:3001 weight=1 max_fails=3 fail_timeout=30s; # 多个实例时启用
    # server 127.0.0.1:3002 weight=1 max_fails=3 fail_timeout=30s;

    # 保持连接配置
    keepalive 32;
    keepalive_timeout 60s;
    keepalive_requests 100;
}

# 主要服务器块 - HTTP重定向到HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name coarch.example.com www.coarch.example.com;

    # 安全头部（即使在HTTP重定向时也设置）
    add_header X-Frame-Options DENY always;
    add_header X-Content-Type-Options nosniff always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # 重定向到HTTPS
    return 301 https://$server_name$request_uri;

    # 访问日志
    access_log /var/log/nginx/coarch_http_access.log combined buffer=32k flush=5s;
    error_log /var/log/nginx/coarch_http_error.log warn;

    # 根目录（可选，用于显示维护页面）
    root /var/www/html;

    # Let's Encrypt验证路径（ACME挑战）
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
        allow all;
    }
}

# 主要服务器块 - HTTPS
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name coarch.example.com www.coarch.example.com;

    # SSL证书配置
    ssl_certificate /etc/nginx/ssl/coarch.example.com/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/coarch.example.com/privkey.pem;

    # SSL优化配置
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;

    # SSL会话缓存
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    # Diffie-Hellman参数（增强安全性）
    ssl_dhparam /etc/nginx/ssl/dhparam.pem;

    # OCSP装订
    ssl_stapling on;
    ssl_stapling_verify on;
    ssl_trusted_certificate /etc/nginx/ssl/coarch.example.com/chain.pem;

    # 安全头部
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
    add_header X-Frame-Options DENY always;
    add_header X-Content-Type-Options nosniff always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https:; frame-ancestors 'none';" always;
    add_header Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()" always;

    # 前端静态文件
    root /var/www/coarch;
    index index.html;

    # 访问日志
    access_log /var/log/nginx/coarch_access.log combined buffer=32k flush=5s;
    error_log /var/log/nginx/coarch_error.log warn;

    # 主页
    location / {
        try_files $uri $uri/ /index.html;

        # 缓存静态资源
        location ~* \.(jpg|jpeg|png|gif|ico|svg|webp)$ {
            expires 1y;
            add_header Cache-Control "public, immutable";
            access_log off;
        }

        location ~* \.(css|js)$ {
            expires 1y;
            add_header Cache-Control "public, immutable";
            access_log off;
        }

        location ~* \.(woff|woff2|ttf|eot)$ {
            expires 1y;
            add_header Cache-Control "public, immutable";
            access_log off;
        }
    }

    # API代理
    location /api/ {
        proxy_pass http://coarch_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

        # 连接设置
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
        proxy_buffering off;
        proxy_request_buffering off;

        # 缓冲区设置
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;
        proxy_busy_buffers_size 8k;

        # WebSocket支持
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # 禁用代理缓存
        proxy_no_cache 1;
        proxy_cache_bypass 1;

        # CORS头部（如果后端未设置）
        add_header Access-Control-Allow-Origin $http_origin always;
        add_header Access-Control-Allow-Credentials true always;
        add_header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS" always;
        add_header Access-Control-Allow-Headers "Authorization, Content-Type, X-Requested-With" always;

        # 预检请求处理
        if ($request_method = 'OPTIONS') {
            add_header Access-Control-Allow-Origin $http_origin;
            add_header Access-Control-Allow-Credentials true;
            add_header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS";
            add_header Access-Control-Allow-Headers "Authorization, Content-Type, X-Requested-With";
            add_header Access-Control-Max-Age 1728000;
            add_header Content-Type 'text/plain charset=UTF-8';
            add_header Content-Length 0;
            return 204;
        }
    }

    # 上传文件路径
    location /uploads/ {
        proxy_pass http://coarch_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # 文件上传大小限制
        client_max_body_size 100M;

        # 禁用代理缓存
        proxy_no_cache 1;
        proxy_cache_bypass 1;

        # 安全头部
        add_header X-Content-Type-Options nosniff always;
        add_header X-Frame-Options DENY always;
    }

    # 静态文件服务（直接从后端提供）
    location /static/ {
        proxy_pass http://coarch_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # 缓存静态文件
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # 健康检查端点
    location /health {
        access_log off;
        error_log off;

        # 直接返回健康状态
        return 200 "healthy\n";
        add_header Content-Type text/plain;
        add_header Cache-Control "no-cache, no-store, must-revalidate";
    }

    # 状态页面（需要认证）
    location /status {
        access_log off;
        error_log off;

        # 基本认证
        auth_basic "Restricted";
        auth_basic_user_file /etc/nginx/.htpasswd;

        # 代理到后端状态端点
        proxy_pass http://coarch_backend/api/status;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_cache_bypass 1;
        proxy_no_cache 1;
    }

    # 阻止敏感文件访问
    location ~ /\.(ht|git|env) {
        deny all;
        return 404;
    }

    location ~ /\. {
        deny all;
        return 404;
    }

    # 错误页面
    error_page 404 /404.html;
    error_page 500 502 503 504 /50x.html;

    location = /404.html {
        internal;
        root /var/www/html;
    }

    location = /50x.html {
        internal;
        root /var/www/html;
    }
}

# 子域名重定向（www到非www）
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name www.coarch.example.com;

    # 使用相同的SSL证书
    ssl_certificate /etc/nginx/ssl/coarch.example.com/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/coarch.example.com/privkey.pem;

    # 重定向到非www版本
    return 301 https://coarch.example.com$request_uri;
}

